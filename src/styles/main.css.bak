@import "tailwindcss";
@import "element-plus/theme-chalk/dark/css-vars.css";

:root {
  --brand-primary: #a855f7; /* Brighter Purple */
  --brand-secondary: #22d3ee; /* Brighter Cyan */
  --brand-primary-light: #c084fc;
  --brand-secondary-light: #67e8f9;

  /* Gradients */
  --gradient-primary: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
  --gradient-primary-hover: linear-gradient(90deg, var(--brand-primary-light), var(--brand-secondary-light));
  --gradient-background: linear-gradient(180deg, #11111b 0%, #0f0f1a 100%);
  --gradient-card: linear-gradient(145deg, rgba(42, 42, 62, 0.5), rgba(30, 30, 48, 0.5));

  /* Glows */
  --glow-primary: 0 0 15px rgba(124, 58, 237, 0.5), 0 0 5px rgba(124, 58, 237, 0.8);
  --glow-secondary: 0 0 15px rgba(6, 182, 212, 0.5), 0 0 5px rgba(6, 182, 212, 0.8);
  --text-shadow-primary: 0 0 8px rgba(167, 139, 250, 0.7);

  /* Base Colors */
  --bg-base: #0f0f1a;
  --bg-surface: #1a1a2e;
  --bg-glass: rgba(26, 26, 46, 0.6);
  --border-color: #2d2d44;
  --border-color-hover: #7c3aed;

  /* Text */
  --text-primary: #e2e8f0;
  --text-secondary: #94a3b8;
  --text-bright: #ffffff;

  /* System Colors */
  --success: #22c55e;
  --warning: #f59e0b;
  --danger: #ef4444;
}

html, body, #app {
  margin: 0;
  padding: 0;
  height: 100%;
  background-color: var(--bg-base);
  background-image: var(--gradient-background);
  color: var(--text-primary);
  font-family: 'Inter', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  overflow: hidden;
}

html.dark {
  color-scheme: dark;
}

/* Glass morphism utility */
.glass-morphism {
  background: var(--bg-glass);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

/* Custom scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: #3d3d5c;
  border-radius: 3px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--brand-primary);
}

/* General transition */
.transition-all {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Glow utilities */
.glow-border {
  border: 1px solid var(--border-color);
}
.glow-border:hover {
  border-color: var(--border-color-hover);
  box-shadow: var(--glow-primary);
}

.glow-text {
  text-shadow: var(--text-shadow-primary);
}

/* Animations */
@keyframes pulse {
  0%, 100% {
    box-shadow: var(--glow-primary);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 25px rgba(168, 85, 247, 0.8), 0 0 10px rgba(168, 85, 247, 1);
    transform: scale(1.02);
  }
}

@keyframes confetti-rain {
  0% { transform: translateY(-100%) rotateZ(15deg); opacity: 1; }
  100% { transform: translateY(100vh) rotateZ(-15deg); opacity: 0; }
}

@keyframes animated-border {
  0% { border-color: var(--brand-primary); }
  25% { border-color: var(--brand-secondary); }
  50% { border-color: var(--brand-primary-light); }
  75% { border-color: var(--brand-secondary-light); }
  100% { border-color: var(--brand-primary); }
}

/* Element Plus Overrides */
.el-menu {
  border-right: none !important;
  background-color: transparent !important;
}
.el-sub-menu__title:hover, .el-menu-item:hover {
  background-color: rgba(124, 58, 237, 0.1) !important;
}
.el-button--primary {
  background: var(--brand-primary) !important;
  border-color: var(--brand-primary) !important;
  box-shadow: var(--glow-primary);
  transition: all 0.3s ease;
}
.el-button--primary:hover {
  transform: translateY(-2px);
  filter: brightness(1.2);
  box-shadow: 0 0 25px rgba(124, 58, 237, 0.8);
}
.el-card {
  background: var(--gradient-card) !important;
  border: 1px solid var(--border-color) !important;
  border-radius: 12px !important;
}
.el-input__wrapper {
  background-color: rgba(0,0,0,0.2) !important;
  box-shadow: none !important;
  border: 1px solid var(--border-color) !important;
}
.el-input__wrapper.is-focus {
  border-color: var(--brand-primary) !important;
  box-shadow: var(--glow-primary) !important;
}
.el-tag {
  background-color: rgba(124, 58, 237, 0.15) !important;
  color: var(--brand-primary-light) !important;
  border: 1px solid rgba(124, 58, 237, 0.3) !important;
}

/* Responsive adjustments */
@media (max-width: 767px) {
  .app-layout {
    grid-template-columns: 1fr;
    grid-template-areas:
      "header"
      "main";
  }

  .app-sidebar {
    position: fixed;
    top: 0;
    left: -250px; /* Hidden by default */
    height: 100%;
    z-index: 1000;
    transition: left 0.3s ease-in-out;
  }

  .app-sidebar.is-open {
    left: 0;
  }

  .main-content {
    padding: 1rem;
  }
}